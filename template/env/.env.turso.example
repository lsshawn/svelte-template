# --- Database: Turso (libSQL) ---
DATABASE_URL="libsql://your-db-name.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token"

# --- Email (OTP login) ---
# 'console' prints codes to the server log (great for dev). Use 'mailgun' in prod.
EMAIL_PROVIDER="console"
EMAIL_FROM="__APP_TITLE__ <noreply@example.com>"
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# --- OAuth (optional) — buttons only show when these are set ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Public ---
PUBLIC_DOMAIN="http://localhost:5173"
